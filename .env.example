# ============================================================
# LotusHacks - Root .env file (docker-compose / local root env)
# Sao chép thành .env và điền các giá trị thực
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
QWEN_API_KEY=
HF_TOKEN=hf_...
CHAT_LLM_MODEL=gpt-4o-mini

# --- Agent Runtime ---
AGENT_LLM_MODEL=gpt-4o-mini
FALLBACK_LLM_MODEL=qwen-plus
AGENT_LLM_TEMPERATURE=0
TRIAGE_RAG_K=5
COVERAGE_RAG_K=5

# --- Zilliz RAG ---
ZILLIZ_URI=https://YOUR-CLUSTER.api.aws-ap-southeast-1.vectordb.zillizcloud.com:19534
MILVUS_HOST=https://YOUR-CLUSTER.api.aws-ap-southeast-1.vectordb.zillizcloud.com:19534/
MILVUS_PORT=19534
ZILLIZ_TOKEN=YOUR_ZILLIZ_API_KEY
ZILLIZ_COLLECTION_NAME=insurance_policies
ZILLIZ_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
ZILLIZ_EMBED_DIM=768
ZILLIZ_TIMEOUT_SEC=15

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=lotushacks

# --- JWT ---
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# --- Google OAuth ---
GOOGLE_CLIENT_ID=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
